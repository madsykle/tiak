# Tiak Server Configuration
# Copy this file to .env and fill in your values.

# --- Server ---
PORT=4697
HOST=0.0.0.0

# Root directory for media storage
DATA_ROOT=data

# MongoDB connection string (required)
# Local: mongodb://localhost:27017/tiak
# Atlas: mongodb+srv://<user>:<password>@cluster.mongodb.net/tiak
MONGODB_URI=mongodb://localhost:27017/tiak

# Max concurrent download jobs
MAX_CONCURRENT_DOWNLOADS=4

# --- CORS ---
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# --- Authentication ---
# Set to true to enable JWT-based auth (recommended for production)
ENABLE_AUTH=true

# SECURITY: Generate a strong secret with: openssl rand -base64 32
# Must be at least 32 characters. NEVER commit your real secret to git.
JWT_SECRET=CHANGE_ME_IN_PRODUCTION_must_be_at_least_32_characters

# Token lifetime in hours
JWT_EXPIRY_HOURS=24

# --- Security Settings ---
MAX_UPLOAD_SIZE=10485760
ENABLE_RATE_LIMITING=false
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60
ENABLE_HTTPS_REDIRECT=false
SECURITY_HEADERS=true

# --- yt-dlp ---
# Path to python interpreter for yt-dlp
YT_DLP_PYTHON=venv_python/bin/python
# Path to yt-dlp binary
YT_DLP_BINARY=bin/yt-dlp

# --- Admin Setup ---
# Required for initial admin user creation
# Change this before deploying to production!
ADMIN_PASSWORD=change_this_before_deploy

# --- Logging ---
RUST_LOG=info